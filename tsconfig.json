{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "moduleResolution": "Node",
      "outDir": "dist",
      "rootDir": "src",
      "declaration": true,
      "sourceMap": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "strict": true,
      "skipLibCheck": true,
      "lib": ["ES2020", "DOM"],
      "baseUrl": "."
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
  }